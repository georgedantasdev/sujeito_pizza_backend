model Pizzeria {
  id        String    @id @default(uuid())
  name      String
  document  String    @unique
  users     User[]
  products  Product[]
  tables    Table[]
  coupons   Coupon[]
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([deletedAt])
  @@map("pizzerias")
}
