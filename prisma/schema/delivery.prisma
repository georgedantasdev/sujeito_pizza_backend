enum DeliveryStatus {
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model Delivery {
  id            String         @id @default(uuid())
  customerName  String
  status        DeliveryStatus @default(PREPARING)
  totalPrice    Decimal        @default(0) @db.Decimal(10, 2)
  paymentMethod PaymentMethod?
  discount      Decimal        @default(0) @db.Decimal(10, 2)
  paidAt        DateTime?
  note          String?
  pizzeriaId    String
  pizzeria      Pizzeria       @relation(fields: [pizzeriaId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  items         DeliveryItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([pizzeriaId])
  @@index([userId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryItem {
  id         String         @id @default(uuid())
  quantity   Int
  price      Decimal        @db.Decimal(10, 2)
  note       String?
  deliveryId String
  delivery   Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  productId  String
  product    Product        @relation(fields: [productId], references: [id])
  sizeId     String?
  size       ProductSize?   @relation(fields: [sizeId], references: [id])
  flavorId   String?
  flavor     ProductFlavor? @relation(fields: [flavorId], references: [id])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([deliveryId])
  @@map("delivery_items")
}
